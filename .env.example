# Internal LLM (OpenAI-compatible)
LLM_BASE_URL=https://internal-llm.company.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o

# goodocs Requirements Board
GOODOCS_BASE_URL=https://goodocs.company.com/api
GOODOCS_API_KEY=your-goodocs-api-key

# Git Server (Bitbucket Server / Gitea)
GIT_BASE_URL=https://git.company.com
GIT_API_TOKEN=your-git-api-token
# Comma-separated: "PROJECT_KEY/repo-name,PROJECT_KEY/repo-name2"
GIT_REPOS=PROJ/backend,PROJ/frontend
# Pattern to extract ITSM story numbers from commit messages (regex)
ITSM_PATTERN=(?:ITSM|STRY)-\d+

# Report Storage (SQLite)
REPORT_DB_PATH=./data/reports.db

# QA Guide MD file (LLM context + web editor)
QA_GUIDE_PATH=./qa_guide.md

# Web Dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Scheduler (cron expression)
CRON_SCHEDULE=0 22 * * 1-5

# How many hours back to look for commits per run
LOOKBACK_HOURS=24
